# Copy to .env and fill in your values. Do not commit .env.
# For Netlify: set these in Site settings → Environment variables (Build & deploy → Environment).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_publishable_key

# Cloudinary (for livestock photos). Copy data/config.example.js to data/config.js and set the upload preset.
CLOUDINARY_CLOUD_NAME=dprfszxkv
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
